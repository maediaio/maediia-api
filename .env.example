# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/maediia
DATABASE_URL_SYNC=postgresql://user:password@localhost:5432/maediia

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=change-this-to-a-secure-random-string-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# App Settings
APP_NAME="Maediia API"
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Voice Settings
VOICE_DEFAULT_MODEL=alloy
VOICE_WEBSOCKET_TIMEOUT=300

# External Services (add when integrating)
# OPENAI_API_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
